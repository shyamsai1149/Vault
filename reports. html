<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StudyOS — Reports</title>
  <link rel="stylesheet" href="assets/css/style.css" />
  <link href="[fonts.googleapis.com](https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap)" rel="stylesheet" />
  <script src="[cdn.jsdelivr.net](https://cdn.jsdelivr.net/npm/chart.js)"></script>
</head>
<body>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo"><span class="logo-icon">🧠</span><span class="logo-text">StudyOS</span></div>
    <nav class="sidebar-nav">
      <a href="index.html" class="nav-item"><span class="nav-icon">⚡</span><span class="nav-label">Dashboard</span></a>
      <a href="study.html" class="nav-item"><span class="nav-icon">📚</span><span class="nav-label">Study Tracker</span></a>
      <a href="goals.html" class="nav-item"><span class="nav-icon">🎯</span><span class="nav-label">Goals & Tasks</span></a>
      <a href="reports.html" class="nav-item active"><span class="nav-icon">📊</span><span class="nav-label">Reports</span></a>
      <a href="settings.html" class="nav-item"><span class="nav-icon">⚙️</span><span class="nav-label">Settings</span></a>
    </nav>
    <div class="sidebar-footer"><div class="streak-badge"><span id="sidebar-streak">🔥 0 day streak</span></div></div>
  </aside>
  <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>

  <main class="main-content">
    <header class="topbar">
      <div class="topbar-left">
        <h1 class="page-title">Reports & Analytics</h1>
        <p class="page-subtitle">Weekly performance summary</p>
      </div>
      <div class="topbar-right">
        <button class="btn-ai-plan" id="generateReportBtn">✨ AI Analysis</button>
      </div>
    </header>

    <!-- Weekly Summary -->
    <div class="report-summary-grid">
      <div class="report-stat"><div class="r-val" id="rStudyTotal">0h</div><div class="r-lbl">Study Hours (7 days)</div></div>
      <div class="report-stat"><div class="r-val" id="rTasksTotal">0</div><div class="r-lbl">Tasks Completed</div></div>
      <div class="report-stat"><div class="r-val" id="rAvgProductivity">0%</div><div class="r-lbl">Avg Productivity</div></div>
      <div class="report-stat"><div class="r-val" id="rStreakMax">0</div><div class="r-lbl">Best Streak</div></div>
      <div class="report-stat"><div class="r-val" id="rMobileAvg">0h</div><div class="r-lbl">Avg Mobile/Day</div></div>
      <div class="report-stat"><div class="r-val" id="rGoalHitRate">0%</div><div class="r-lbl">Goal Hit Rate</div></div>
    </div>

    <!-- Charts -->
    <div class="two-col-grid">
      <div class="card chart-card">
        <div class="card-header"><h3>📈 Study Hours Trend</h3></div>
        <canvas id="studyTrendChart" height="200"></canvas>
      </div>
      <div class="card chart-card">
        <div class="card-header"><h3>🎯 Subject Progress Radar</h3></div>
        <canvas id="subjectRadar" height="200"></canvas>
      </div>
    </div>

    <!-- AI Strengths & Weaknesses -->
    <div class="card" style="margin-bottom:24px">
      <div class="card-header">
        <h3>🧠 AI Strengths & Weaknesses Analysis</h3>
        <span class="badge badge-ai">Gemini</span>
      </div>
      <div id="aiAnalysisContent">
        <div class="ai-placeholder"><span>🧠</span><p>Click "AI Analysis" to get personalized insights</p></div>
      </div>
    </div>

    <!-- Daily Breakdown Table -->
    <div class="card">
      <div class="card-header"><h3>📅 Daily Breakdown (Last 7 Days)</h3></div>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead>
            <tr style="color:#64748b;border-bottom:1px solid #2a3550">
              <th style="text-align:left;padding:10px">Date</th>
              <th style="text-align:left;padding:10px">Study Time</th>
              <th style="text-align:left;padding:10px">Mobile Usage</th>
              <th style="text-align:left;padding:10px">Tasks Done</th>
              <th style="text-align:left;padding:10px">Productivity</th>
            </tr>
          </thead>
          <tbody id="dailyBreakdownBody"></tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="assets/js/db.js"></script>
  <script src="assets/js/ai.js"></script>
  <script src="assets/js/charts.js"></script>
  <script src="assets/js/notifications.js"></script>
  <script>
    Notify.init();

    async function loadReports() {
      await DB.open();
      const activities = await DB.getActivitiesRange(7);
      const tasks = await DB.getAll(DB.STORES.TASKS);
      const subjects = await DB.getSubjects();

      // Weekly totals
      const studyMins = activities.filter(a => a.type === 'study' || a.type === 'project')
        .reduce((s, a) => s + a.duration, 0);
      const mobileMins = activities.filter(a => a.type === 'mobile')
        .reduce((s, a) => s + a.duration, 0);

      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
      const recentTasks = tasks.filter(t => new Date(t.createdAt) >= sevenDaysAgo);
      const completedTasks = recentTasks.filter(t => t.completed);

      document.getElementById('rStudyTotal').textContent = `${Math.floor(studyMins / 60)}h`;
      document.getElementById('rTasksTotal').textContent = completedTasks.length;
      document.getElementById('rMobileAvg').textContent = `${(mobileMins / 7 / 60).toFixed(1)}h`;
      const goalHitRate = recentTasks.length > 0 ? Math.round((completedTasks.length / recentTasks.length) * 100) : 0;
      document.getElementById('rGoalHitRate').textContent = `${goalHitRate}%`;

      // Streak
      const studyStreak = await DB.getStreak('study');
      document.getElementById('rStreakMax').textContent = studyStreak?.count || 0;
      const el = document.getElementById('sidebar-streak');
      if (el) el.textContent = `🔥 ${studyStreak?.count || 0} day streak`;

      // Build daily data
      const dailyData = {};
      for (let i = 6; i >= 0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        const dateStr = d.toISOString().split('T')[0];
        dailyData[dateStr] = { study: 0, mobile: 0, sleep: 0, tasksCompleted: 0 };
      }

      activities.forEach(a => {
        const date = new Date(a.timestamp).toISOString().split('T')[0];
        if (dailyData[date]) {
          if (a.type === 'study' || a.type === 'project') dailyData[date].study += a.duration;
          if (a.type === 'mobile') dailyData[date].mobile += a.duration;
          if (a.type === 'sleep') dailyData[date].sleep += a.duration;
        }
      });

      tasks.forEach(t => {
        if (t.completed && t.completedAt) {
          const date = new Date(t.completedAt).toISOString().split('T')[0];
          if (dailyData[date]) dailyData[date].tasksCompleted++;
        }
      });

      const labels = Object.keys(dailyData).map(d => new Date(d).toLocaleDateString('en-IN', { weekday: 'short', month: 'short', day: 'numeric' }));
      const studyHours = Object.values(dailyData).map(d => +(d.study / 60).toFixed(1));
      const avgProductivity = studyHours.reduce((a, b) => a + b, 0) / 7;
      document.getElementById('rAvgProductivity').textContent = `${Math.min(100, Math.round((avgProductivity / 6) * 100))}%`;

      // Charts
      Charts.renderLineChart('studyTrendChart', labels, {
        label: 'Study Hours', data: studyHours
      });

      if (subjects.length > 0) {
        Charts.renderSubjectRadarChart('subjectRadar', subjects.map(s => ({ name: s.name, progress: s.progress })));
      }

      // Daily breakdown table
      const tbody = document.getElementById('dailyBreakdownBody');
      tbody.innerHTML = Object.entries(dailyData).reverse().map(([date, d]) => {
        const prod = Math.min(100, Math.round((d.study / 360) * 100));
        const dateDisp = new Date(date).toLocaleDateString('en-IN', { weekday: 'short', month: 'short', day: 'numeric' });
        const prodColor = prod >= 70 ? '#10b981' : prod >= 40 ? '#f59e0b' : '#ef4444';
        return `<tr style="border-bottom:1px solid #2a3550">
          <td style="padding:10px 8px">${dateDisp}</td>
          <td style="padding:10px 8px;color:#3b82f6">${Math.floor(d.study / 60)}h ${d.study % 60}m</td>
          <td style="padding:10px 8px;color:#f59e0b">${Math.floor(d.mobile / 60)}h ${d.mobile % 60}m</td>
          <td style="padding:10px 8px;color:#10b981">${d.tasksCompleted}</td>
          <td style="padding:10px 8px"><span style="color:${prodColor};font-weight:700">${prod}%</span></td>
        </tr>`;
      }).join('');
    }

    document.getElementById('generateReportBtn').addEventListener('click', async () => {
      const el = document.getElementById('aiAnalysisContent');
      el.innerHTML = '<div class="ai-loading">Analyzing your performance</div>';

      const subjects = await DB.getSubjects();
      const activities = await DB.getActivitiesRange(7);

      const analysis = await AI.analyzeStrengthsWeaknesses(subjects, activities);
      if (analysis) {
        el.innerHTML = `<div style="font-size:13px;line-height:1.8;color:#94a3b8;white-space:pre-line">${analysis}</div>`;
      } else {
        const strong = subjects.filter(s => s.progress > 60).map(s => s.name).join(', ') || 'Not enough data';
        const weak = subjects.filter(s => s.progress < 40).map(s => s.name).join(', ') || 'Needs more tracking';
        el.innerHTML = `
          <div style="display:flex;flex-direction:column;gap:10px">
            <div style="padding:12px;background:#0a1628;border-radius:8px;border-left:3px solid #10b981">
              <strong style="color:#10b981">💪 Strengths:</strong> <span style="color:#94a3b8">${strong}</span>
            </div>
            <div style="padding:12px;background:#0a1628;border-radius:8px;border-left:3px solid #ef4444">
              <strong style="color:#ef4444">⚠️ Needs Focus:</strong> <span style="color:#94a3b8">${weak}</span>
            </div>
            <p style="font-size:12px;color:#64748b">Add your Gemini API key in Settings for detailed AI analysis.</p>
          </div>`;
      }
    });

    document.getElementById('mobileMenuBtn').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    loadReports();
  </script>
</body>
</html>
