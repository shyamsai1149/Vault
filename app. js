// ============================================
// StudyOS — Main App Controller
// ============================================

const App = (() => {
  // State
  let profile = null;
  let subjects = [];
  let todayTasks = [];
  let todayActivities = [];
  let timerInterval = null;
  let timerSeconds = 0;
  let timerRunning = false;
  let lastActiveTime = Date.now();

  // Default subjects
  const DEFAULT_SUBJECTS = [
    { name: 'Java', icon: '☕', progress: 0, studyMinutes: 0, color: '#f59e0b' },
    { name: 'DSA', icon: '🌳', progress: 0, studyMinutes: 0, color: '#3b82f6' },
    { name: 'SQL', icon: '🗄️', progress: 0, studyMinutes: 0, color: '#10b981' },
    { name: 'Aptitude', icon: '🧮', progress: 0, studyMinutes: 0, color: '#8b5cf6' },
    { name: 'English', icon: '📝', progress: 0, studyMinutes: 0, color: '#06b6d4' },
    { name: 'Project', icon: '💻', progress: 0, studyMinutes: 0, color: '#ef4444' },
    { name: 'ECET', icon: '📐', progress: 0, studyMinutes: 0, color: '#34d399' }
  ];

  // College timetable slots
  const COLLEGE_SLOTS = [
    { time: '09:30', endTime: '10:20', label: 'Morning Lecture 1', icon: '🏫' },
    { time: '10:20', endTime: '11:10', label: 'Morning Lecture 2', icon: '🏫' },
    { time: '11:10', endTime: '11:20', label: 'Short Break', icon: '☕' },
    { time: '11:20', endTime: '12:10', label: 'Morning Lecture 3', icon: '🏫' },
    { time: '12:10', endTime: '13:00', label: 'Morning Lecture 4', icon: '🏫' },
    { time: '13:00', endTime: '13:40', label: 'Lunch Break', icon: '🍱' },
    { time: '13:40', endTime: '14:30', label: 'Afternoon Lecture 5', icon: '🏫' },
    { time: '14:30', endTime: '15:20', label: 'Afternoon Lecture 6', icon: '🏫' },
    { time: '15:20', endTime: '16:00', label: 'Lab / Practical', icon: '🔬' },
    { time: '16:00', endTime: '17:00', label: 'Travel / Rest', icon: '🚌' },
    { time: '17:00', endTime: '19:00', label: 'Self Study Block 1', icon: '📚' },
    { time: '19:00', endTime: '19:30', label: 'Exercise / Walk', icon: '🏃' },
    { time: '19:30', endTime: '21:30', label: 'Self Study Block 2', icon: '📚' },
    { time: '21:30', endTime: '22:00', label: 'Revision / Notes', icon: '📝' },
    { time: '22:00', endTime: '23:00', label: 'Relaxation / Wind-down', icon: '🎵' },
    { time: '23:00', endTime: '23:30', label: 'Sleep Prep', icon: '😴' }
  ];

  // ---- INIT ----
  async function init() {
    await DB.open();
    Notify.init();

    // Check profile
    profile = await DB.getProfile();
    const cached = localStorage.getItem('studyos_profile');
    if (cached) profile = JSON.parse(cached);

    if (!profile) {
      showSetupModal();
      hideLoader();
      return;
    }

    await loadSubjects();
    await loadTodayData();
    renderAll();
    setupEventListeners();
    startProcrastinationMonitor();
    Notify.setupDailyReminders();
    Notify.requestPermission();

    // Set avatar
    document.getElementById('avatarInitial').textContent = profile.name?.[0]?.toUpperCase() || 'S';

    // Date display
    document.getElementById('dateDisplay').textContent = new Date().toLocaleDateString('en-IN', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });

    // Load AI quote
    loadMotivationalQuote();
    loadRecommendation();

    hideLoader();
  }

  function hideLoader() {
    setTimeout(() => {
      const loader = document.getElementById('loader');
      if (loader) { loader.classList.add('hidden'); setTimeout(() => loader.remove(), 500); }
    }, 800);
  }

  // ---- LOAD DATA ----
  async function loadSubjects() {
    const stored = await DB.getSubjects();
    if (stored.length === 0) {
      // Initialize defaults
      for (const s of DEFAULT_SUBJECTS) await DB.saveSubject(s);
      subjects = [...DEFAULT_SUBJECTS];
    } else {
      subjects = stored;
    }
  }

  async function loadTodayData() {
    todayTasks = await DB.getTodayTasks();
    todayActivities = await DB.getTodayActivities();
  }

  // ---- RENDER ALL ----
  function renderAll() {
    renderTimetable();
    renderStats();
    renderSubjects();
    renderTasks();
    renderRecentLogs();
    renderStreaks();
    renderCharts();
  }

  // ---- TIMETABLE ----
  function renderTimetable() {
    const list = document.getElementById('timetableList');
    if (!list) return;

    const now = new Date();
    const currentMins = now.getHours() * 60 + now.getMinutes();
    let html = '';

    COLLEGE_SLOTS.forEach(slot => {
      const [sh, sm] = slot.time.split(':').map(Number);
      const [eh, em] = slot.endTime.split(':').map(Number);
      const startMins = sh * 60 + sm;
      const endMins = eh * 60 + em;
      const isCurrent = currentMins >= startMins && currentMins < endMins;
      const isCompleted = currentMins >= endMins;

      html += `
        <div class="timetable-item ${isCurrent ? 'current' : ''} ${isCompleted ? 'completed' : ''}">
          <span class="slot-time">${slot.time}–${slot.endTime}</span>
          <span class="slot-icon">${slot.icon}</span>
          <span class="slot-label">${slot.label}</span>
          ${isCurrent ? '<span class="slot-status badge badge-live">NOW</span>' : ''}
        </div>`;
    });

    list.innerHTML = html;

    // Scroll to current slot
    setTimeout(() => {
      const current = list.querySelector('.current');
      if (current) current.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 300);
  }

  // ---- STATS ----
  function renderStats() {
    const studyMins = todayActivities
      .filter(a => a.type === 'study' || a.type === 'project')
      .reduce((sum, a) => sum + (a.duration || 0), 0);
    const mobileMins = todayActivities
      .filter(a => a.type === 'mobile')
      .reduce((sum, a) => sum + (a.duration || 0), 0);
    const sleepMins = todayActivities
      .filter(a => a.type === 'sleep')
      .reduce((sum, a) => sum + (a.duration || 0), 0);

    const studyGoalMins = (profile?.studyGoal || 6) * 60;
    const mobileLimitMins = (profile?.mobileLimit || 2) * 60;
    const sleepGoalMins = 7.5 * 60;

    // Study
    document.getElementById('statStudyTime').textContent =
      `${Math.floor(studyMins / 60)}h ${studyMins % 60}m`;
    animateBar('barStudy', (studyMins / studyGoalMins) * 100);

    // Mobile
    document.getElementById('statMobile').textContent =
      `${Math.floor(mobileMins / 60)}h ${mobileMins % 60}m`;
    const mobileBar = document.getElementById('barMobile');
    mobileBar.style.background = mobileMins > mobileLimitMins ? '#ef4444' : '#f59e0b';
    animateBar('barMobile', (mobileMins / mobileLimitMins) * 100);

    // Sleep
    document.getElementById('statSleep').textContent = `${Math.round(sleepMins / 60)}h`;
    animateBar('barSleep', (sleepMins / sleepGoalMins) * 100);

    // Productivity
    const productivity = calculateProductivity(studyMins, mobileMins, sleepMins, studyGoalMins, mobileLimitMins);
    document.getElementById('statProductivity').textContent = `${productivity}%`;
    animateBar('barProductivity', productivity);
    document.getElementById('productivityLabel').textContent =
      productivity >= 80 ? '🔥 Excellent!' : productivity >= 60 ? '💪 Good Progress' : productivity >= 40 ? '📈 Keep Going' : '💤 Just Starting';
  }

  function calculateProductivity(studyMins, mobileMins, sleepMins, studyGoal, mobileLimit) {
    let score = 0;
    score += Math.min(50, (studyMins / studyGoal) * 50);
    score += Math.max(0, 20 - (mobileMins > mobileLimit ? (mobileMins - mobileLimit) / 30 * 5 : 0));
    score += sleepMins >= 360 ? 15 : (sleepMins / 360) * 15;

    const completedRatio = todayTasks.length > 0
      ? todayTasks.filter(t => t.completed).length / todayTasks.length
      : 0;
    score += completedRatio * 15;

    return Math.min(100, Math.round(score));
  }

  function animateBar(id, pct) {
    const bar = document.getElementById(id);
    if (bar) {
      requestAnimationFrame(() => { bar.style.width = `${Math.min(100, pct)}%`; });
    }
  }

  // ---- SUBJECTS ----
  function renderSubjects() {
    const grid = document.getElementById('subjectsGrid');
    if (!grid) return;

    const colors = {
      Java: '#f59e0b', DSA: '#3b82f6', SQL: '#10b981',
      Aptitude: '#8b5cf6', English: '#06b6d4', Project: '#ef4444', ECET: '#34d399'
    };

    grid.innerHTML = subjects.map(s => {
      const color = colors[s.name] || '#3b82f6';
      return `
        <div class="subject-item">
          <div class="subject-header">
            <span class="subject-name">${s.icon} ${s.name}</span>
            <span class="subject-pct" style="color:${color}">${s.progress}%</span>
          </div>
          <div class="progress-bar-wrap">
            <div class="progress-bar" style="width:${s.progress}%;background:${color}"></div>
          </div>
          <div class="subject-meta">${s.studyMinutes || 0} mins studied</div>
        </div>`;
    }).join('');
  }

  // ---- TASKS ----
  function renderTasks() {
    const list = document.getElementById('tasksList');
    const footer = document.getElementById('tasksFooter');
    if (!list) return;

    if (todayTasks.length === 0) {
      list.innerHTML = '<p class="empty-text">No tasks yet. Add your first task! 🎯</p>';
      if (footer) footer.innerHTML = '';
      return;
    }

    const sorted = [...todayTasks].sort((a, b) => {
      const pOrder = { high: 0, medium: 1, low: 2 };
      return pOrder[a.priority] - pOrder[b.priority];
    });

    list.innerHTML = sorted.map(task => `
      <div class="task-item ${task.completed ? 'completed' : ''}" data-id="${task.id}">
        <div class="task-check ${task.completed ? 'done' : ''}" onclick="App.toggleTask(${task.id})">
          ${task.completed ? '✓' : ''}
        </div>
        <span class="task-name">${task.name}</span>
        <div class="task-meta">
          <span class="task-cat ${task.category}">${task.category.toUpperCase()}</span>
          <div class="priority-dot ${task.priority}"></div>
          ${task.estimatedTime ? `<span style="font-size:10px;color:#64748b">${task.estimatedTime}m</span>` : ''}
        </div>
        <button class="task-del" onclick="App.deleteTask(${task.id})">✕</button>
      </div>`).join('');

    const done = todayTasks.filter(t => t.completed).length;
    if (footer) footer.innerHTML = `${done}/${todayTasks.length} tasks completed`;
  }

  // ---- RECENT LOGS ----
  function renderRecentLogs() {
    const container = document.getElementById('recentLogs');
    if (!container) return;

    const recent = [...todayActivities].reverse().slice(0, 5);
    if (recent.length === 0) {
      container.innerHTML = '<p class="empty-text">No logs yet today.</p>';
      return;
    }

    const typeLabels = {
      study: '📚 Study', break: '☕ Break', exercise: '🏃 Exercise',
      mobile: '📱 Mobile', sleep: '😴 Sleep', college: '🏫 College', project: '💻 Project'
    };

    container.innerHTML = recent.map(log => {
      const ago = getTimeAgo(log.timestamp);
      return `
        <div class="log-item">
          <span class="log-type">${typeLabels[log.type] || log.type}</span>
          <span>${log.duration}m${log.note ? ` · ${log.note}` : ''}</span>
          <span class="log-time-ago">${ago}</span>
        </div>`;
    }).join('');
  }

  // ---- STREAKS ----
  async function renderStreaks() {
    const list = document.getElementById('streaksList');
    if (!list) return;

    const types = [
      { type: 'study', label: 'Study Streak', icon: '📚' },
      { type: 'exercise', label: 'Exercise Streak', icon: '🏃' },
      { type: 'sleep', label: 'Sleep Streak', icon: '😴' }
    ];

    let html = '';
    for (const t of types) {
      const s = await DB.getStreak(t.type);
      const count = s?.count || 0;
      html += `
        <div class="streak-item">
          <span class="streak-icon">${t.icon}</span>
          <div class="streak-info">
            <div class="streak-name">${t.label}</div>
            <div class="streak-count">${count > 0 ? `Last active: ${s?.lastDate || 'Today'}` : 'Not started yet'}</div>
          </div>
          <span class="streak-flame">${count}🔥</span>
        </div>`;
    }

    list.innerHTML = html;

    // Update sidebar streak
    const studyStreak = await DB.getStreak('study');
    const el = document.getElementById('sidebar-streak');
    if (el) el.textContent = `🔥 ${studyStreak?.count || 0} day streak`;
  }

  // ---- CHARTS ----
  async function renderCharts() {
    // Build weekly data
    const last7 = await DB.getActivitiesRange(7);
    const weeklyStudy = new Array(7).fill(0);
    const weeklyMobile = new Array(7).fill(0);
    const today = new Date();

    last7.forEach(act => {
      const actDate = new Date(act.timestamp);
      const diff = Math.floor((today - actDate) / (1000 * 60 * 60 * 24));
      const idx = 6 - diff;
      if (idx >= 0 && idx < 7) {
        if (act.type === 'study' || act.type === 'project') {
          weeklyStudy[idx] += (act.duration || 0) / 60;
        }
        if (act.type === 'mobile') {
          weeklyMobile[idx] += (act.duration || 0) / 60;
        }
      }
    });

    Charts.renderWeeklyChart('weeklyChart', {
      study: weeklyStudy.map(v => Math.round(v * 10) / 10),
      mobile: weeklyMobile.map(v => Math.round(v * 10) / 10)
    });

    // Donut chart
    const typeTotals = {};
    const typeLabels = {
      study: 'Study', break: 'Break', exercise: 'Exercise',
      mobile: 'Mobile', sleep: 'Sleep', college: 'College', project: 'Project'
    };
    todayActivities.forEach(a => {
      const key = typeLabels[a.type] || a.type;
      typeTotals[key] = (typeTotals[key] || 0) + (a.duration || 0);
    });

    Charts.renderDonutChart('donutChart', typeTotals);
  }

  // ---- AI FEATURES ----
  async function loadMotivationalQuote() {
    const el = document.getElementById('motivationText');
    if (!el) return;

    const productivityScore = parseInt(document.getElementById('statProductivity')?.textContent || '0');

    try {
      const quote = await AI.getMotivationalQuote(profile, productivityScore);
      el.textContent = quote || AI.getFallbackQuote();
    } catch {
      el.textContent = AI.getFallbackQuote();
    }
  }

  async function generateDailyPlan() {
    const el = document.getElementById('aiPlanContent');
    if (!el) return;

    el.innerHTML = '<div class="ai-loading">Generating your personalized plan</div>';

    const studyMins = todayActivities
      .filter(a => a.type === 'study')
      .reduce((sum, a) => sum + (a.duration || 0), 0);

    const stats = {
      studyMins,
      completedTasks: todayTasks.filter(t => t.completed).length,
      totalTasks: todayTasks.length
    };

    try {
      const plan = await AI.generateDailyPlan(profile, stats, subjects);
      if (plan) {
        renderAIPlan(el, plan);
      } else {
        el.innerHTML = renderFallbackPlan();
      }
    } catch {
      el.innerHTML = renderFallbackPlan();
    }
  }

  function renderAIPlan(container, planText) {
    const lines = planText.split('\n').filter(l => l.trim());
    let html = '';
    lines.forEach(line => {
      if (line.trim()) {
        html += `<div class="plan-item"><span>▸</span><span>${line.trim()}</span></div>`;
      }
    });
    container.innerHTML = html || `<div class="plan-item"><span>▸</span><span>${planText}</span></div>`;
  }

  function renderFallbackPlan() {
    const hour = new Date().getHours();
    const items = hour < 12
      ? ['5:00 PM - 6:00 PM: Java OOP + Collections review', '6:00 PM - 7:00 PM: DSA - Array/LinkedList problems', '7:30 PM - 8:30 PM: SQL Queries practice', '8:30 PM - 9:00 PM: Aptitude - Number Series', '9:00 PM - 9:30 PM: English - Reading Comprehension']
      : ['Evening: Focus on Java Collections (1h)', 'DSA: Solve 3 LeetCode easy problems (1h)', 'SQL: Write 10 practice queries (45m)', 'Aptitude: 20 questions timed practice (30m)', 'Revise today\'s college notes (30m)'];
    return items.map(i => `<div class="plan-item"><span>▸</span><span>${i}</span></div>`).join('');
  }

  async function loadRecommendation() {
    const el = document.getElementById('recommendationContent');
    if (!el) return;

    try {
      const rec = await AI.getRecommendation(profile, todayActivities, subjects, todayTasks);
      if (rec) {
        el.innerHTML = `<div class="rec-item"><strong>🎯 Next Best Action</strong>${rec}</div>`;
      } else {
        el.innerHTML = getFallbackRecommendation();
      }
    } catch {
      el.innerHTML = getFallbackRecommendation();
    }
  }

  function getFallbackRecommendation() {
    const weak = subjects.filter(s => s.progress < 40);
    const subject = weak.length > 0 ? weak[0].name : 'DSA';
    return `<div class="rec-item"><strong>🎯 Focus on ${subject}</strong>This subject needs the most attention. Open a problem-solving resource now and spend 45 focused minutes on it.</div>`;
  }

  // ---- PROCRASTINATION MONITOR ----
  function startProcrastinationMonitor() {
    setInterval(async () => {
      const idleMins = Math.floor((Date.now() - lastActiveTime) / 60000);
      if (idleMins >= 90) { // Alert after 90 mins of no logging
        const alert = document.getElementById('procrastinationAlert');
        const msg = document.getElementById('procrastinationMsg');
        if (alert && msg) {
          try {
            const intervention = await AI.analyzeProcrastination(
              profile, idleMins,
              todayActivities[todayActivities.length - 1]?.type
            );
            msg.textContent = intervention || `You haven't logged activity for ${idleMins} minutes. Set a 25-minute Pomodoro timer now!`;
          } catch {
            msg.textContent = `${idleMins} minutes without activity. Start with just 5 minutes — momentum builds from there!`;
          }
          alert.style.display = 'flex';
        }
      }
    }, 300000); // Check every 5 minutes
  }

  // ---- LOG ACTIVITY ----
  async function logActivity() {
    const type = document.getElementById('logType').value;
    const duration = parseInt(document.getElementById('logDuration').value);
    const note = document.getElementById('logNote').value.trim();

    if (!duration || duration < 1) {
      Notify.show('Please enter a valid duration', 'error');
      return;
    }

    const activity = {
      type, duration, note,
      date: DB.today(),
      timestamp: Date.now()
    };

    await DB.add(DB.STORES.ACTIVITIES, activity);
    lastActiveTime = Date.now();

    // Update subject study time if study activity
    if (type === 'study' && note) {
      const matchedSubject = subjects.find(s =>
        note.toLowerCase().includes(s.name.toLowerCase())
      );
      if (matchedSubject) {
        matchedSubject.studyMinutes = (matchedSubject.studyMinutes || 0) + duration;
        await DB.saveSubject(matchedSubject);
      }
    }

    // Update streaks
    await updateStreak(type);

    // Reset form
    document.getElementById('logDuration').value = '';
    document.getElementById('logNote').value = '';

    // Reload data
    await loadTodayData();
    renderAll();

    Notify.show(`✅ ${type.charAt(0).toUpperCase() + type.slice(1)} activity logged!`, 'success');

    // Hide procrastination alert
    document.getElementById('procrastinationAlert').style.display = 'none';
  }

  // ---- STREAK MANAGEMENT ----
  async function updateStreak(activityType) {
    const streakMap = {
      study: 'study', project: 'study',
      exercise: 'exercise',
      sleep: 'sleep'
    };

    const streakType = streakMap[activityType];
    if (!streakType) return;

    const existing = await DB.getStreak(streakType);
    const today = DB.today();
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    const yesterdayStr = yesterday.toISOString().split('T')[0];

    let count = 1;
    if (existing) {
      if (existing.lastDate === today) return; // Already updated today
      if (existing.lastDate === yesterdayStr) count = (existing.count || 0) + 1;
    }

    await DB.updateStreak(streakType, count, today);
  }

  // ---- TASKS ----
  async function addTask() {
    const name = document.getElementById('taskName').value.trim();
    const category = document.getElementById('taskCategory').value;
    const priority = document.getElementById('taskPriority').value;
    const estimatedTime = parseInt(document.getElementById('taskTime').value) || 0;

    if (!name) {
      Notify.show('Please enter a task name', 'error');
      return;
    }

    const task = {
      name, category, priority, estimatedTime,
      completed: false,
      date: DB.today(),
      createdAt: Date.now()
    };

    await DB.add(DB.STORES.TASKS, task);
    await loadTodayData();
    renderTasks();

    // Close modal
    document.getElementById('taskModal').classList.remove('open');
    document.getElementById('taskName').value = '';
    document.getElementById('taskTime').value = '';

    Notify.show('Task added!', 'success');
  }

  async function toggleTask(taskId) {
    const task = todayTasks.find(t => t.id === taskId);
    if (!task) return;

    task.completed = !task.completed;
    task.completedAt = task.completed ? Date.now() : null;
    await DB.put(DB.STORES.TASKS, task);
    await loadTodayData();
    renderTasks();
    renderStats();

    if (task.completed) {
      Notify.show('Task completed! 🎉', 'success');
    }
  }

  async function deleteTask(taskId) {
    await DB.del(DB.STORES.TASKS, taskId);
    await loadTodayData();
    renderTasks();
    renderStats();
  }

  // ---- PROGRESS MODAL ----
  function openProgressModal() {
    const body = document.getElementById('progressModalBody');
    if (!body) return;

    body.innerHTML = subjects.map(s => `
      <div class="progress-modal-item" style="margin-bottom:14px">
        <label>${s.icon} ${s.name}</label>
        <input type="range" min="0" max="100" value="${s.progress}"
          oninput="this.nextElementSibling.textContent=this.value+'%'"
          data-subject="${s.name}" />
        <span class="pct-display">${s.progress}%</span>
      </div>`).join('');

    body.innerHTML += `<button class="btn-primary full-width" onclick="App.saveProgress()">💾 Save Progress</button>`;
    document.getElementById('progressModal').classList.add('open');
  }

  async function saveProgress() {
    const inputs = document.querySelectorAll('#progressModalBody input[type=range]');
    for (const input of inputs) {
      const subjectName = input.dataset.subject;
      const subject = subjects.find(s => s.name === subjectName);
      if (subject) {
        subject.progress = parseInt(input.value);
        await DB.saveSubject(subject);
      }
    }

    document.getElementById('progressModal').classList.remove('open');
    renderSubjects();
    Notify.show('Progress updated!', 'success');
  }

  // ---- SETUP ----
  function showSetupModal() {
    document.getElementById('setupModal').classList.add('open');
  }

  async function saveSetup() {
    const name = document.getElementById('setupName').value.trim();
    if (!name) { Notify.show('Please enter your name', 'error'); return; }

    const newProfile = {
      name,
      college: document.getElementById('setupCollege').value.trim(),
      semester: document.getElementById('setupSemester').value,
      apiKey: document.getElementById('setupApiKey').value.trim(),
      studyGoal: parseInt(document.getElementById('setupStudyGoal').value) || 6,
      mobileLimit: parseInt(document.getElementById('setupMobileLimit').value) || 2,
      createdAt: Date.now()
    };

    await DB.saveProfile(newProfile);
    localStorage.setItem('studyos_profile', JSON.stringify(newProfile));
    profile = newProfile;

    document.getElementById('setupModal').classList.remove('open');
    document.getElementById('avatarInitial').textContent = name[0].toUpperCase();

    // Init subjects
    for (const s of DEFAULT_SUBJECTS) await DB.saveSubject(s);
    subjects = [...DEFAULT_SUBJECTS];

    renderAll();
    Notify.show(`Welcome to StudyOS, ${name}! 🚀`, 'success');
    loadMotivationalQuote();
  }

  // ---- HELPERS ----
  function getTimeAgo(timestamp) {
    const diff = Date.now() - timestamp;
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return `${mins}m ago`;
    return `${Math.floor(mins / 60)}h ago`;
  }

  // ---- EVENT LISTENERS ----
  function setupEventListeners() {
    document.getElementById('logActivityBtn')?.addEventListener('click', logActivity);
    document.getElementById('generatePlanBtn')?.addEventListener('click', generateDailyPlan);
    document.getElementById('refreshQuote')?.addEventListener('click', loadMotivationalQuote);
    document.getElementById('refreshRecommendation')?.addEventListener('click', loadRecommendation);
    document.getElementById('addTaskBtn')?.addEventListener('click', () => {
      document.getElementById('taskModal').classList.add('open');
    });
    document.getElementById('closeTaskModal')?.addEventListener('click', () => {
      document.getElementById('taskModal').classList.remove('open');
    });
    document.getElementById('saveTaskBtn')?.addEventListener('click', addTask);
    document.getElementById('updateProgressBtn')?.addEventListener('click', openProgressModal);
    document.getElementById('closeProgressModal')?.addEventListener('click', () => {
      document.getElementById('progressModal').classList.remove('open');
    });
    document.getElementById('saveSetupBtn')?.addEventListener('click', saveSetup);
    document.getElementById('dismissAlert')?.addEventListener('click', () => {
      document.getElementById('procrastinationAlert').style.display = 'none';
    });

    // Mobile menu
    document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    // Close modal on overlay click
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) overlay.classList.remove('open');
      });
    });

    // Refresh timetable every minute
    setInterval(renderTimetable, 60000);
  }

  // Public API
  return { init, toggleTask, deleteTask, saveProgress, logActivity };
})();

// Boot
document.addEventListener('DOMContentLoaded', App.init);
